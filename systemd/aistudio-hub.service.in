[Unit]
Description=AI Studio Server Hub
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
WorkingDirectory=@INSTALL_DIR@
Environment=DATA_DIR=@DATA_DIR@
Environment=WEB_DIR=@INSTALL_DIR@/web
Environment=COMFY_URL=http://127.0.0.1:7871
Environment=ACE_URL=http://127.0.0.1:7870
ExecStart=@DATA_DIR@/venv/hub/bin/uvicorn main:app --host 0.0.0.0 --port 7880 --app-dir @INSTALL_DIR@/hub
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
